# ===== PRIZM finance / wallets =====
# Hot wallet: automatic bet intake and automatic payouts. Keep only operating funds here.
PRIZM_HOT_WALLET=PRIZM-FSLA-9FZS-A6SX-3GXNV
# Verification wallet: receives the 1 PRIZM ownership-proof transfer. Defaults to PRIZM_HOT_WALLET if empty.
PRIZM_VERIFICATION_WALLET=
# Cold wallet: public address only. Its passphrase/private key must never be stored on the server.
PRIZM_COLD_WALLET=
PRIZM_ADMIN_WALLET=
# 32 random bytes, base64url without padding. Used for AES-256-GCM encryption of hot passphrase in app_config.
PRIZM_MASTER_KEY=
PRIZM_SWEEP_THRESHOLD=300000
PRIZM_SWEEP_MIN_KEEP=50000

