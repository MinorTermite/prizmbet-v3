<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="0"
                android:startColor="#7A3EF0"
                android:endColor="#19C8FF" />
        </shape>
    </item>
    <item>
        <shape android:shape="rectangle">
            <corners android:radius="22dp" />
            <gradient
                android:angle="0"
                android:startColor="#903EBC"
                android:centerColor="#C84BE0"
                android:endColor="#2ECFFF" />
        </shape>
    </item>
</selector>
