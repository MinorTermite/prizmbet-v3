<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.prizmbet.app.PremiumSplashView
        android:id="@+id/premiumSplash"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:id="@+id/entryScrim"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:alpha="0"
        android:background="@drawable/splash_entry_scrim"
        android:visibility="gone" />

    <LinearLayout
        android:id="@+id/entryPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="20dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="28dp"
        android:alpha="0"
        android:background="@drawable/splash_entry_panel"
        android:elevation="12dp"
        android:orientation="vertical"
        android:padding="22dp"
        android:translationY="36dp"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/splash_badge"
            android:textAllCaps="true"
            android:textColor="#BDE8FF"
            android:textSize="12sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/entryTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/splash_entry_title"
            android:textColor="#FFFFFF"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/entrySubtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:lineSpacingExtra="2dp"
            android:text="@string/splash_entry_subtitle"
            android:textColor="#CFE4FF"
            android:textSize="15sp" />

        <Button
            android:id="@+id/enterButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="20dp"
            android:background="@drawable/splash_enter_button"
            android:text="@string/splash_enter_button"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="17sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/entryHint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/splash_entry_hint"
            android:textColor="#99DDEBFF"
            android:textSize="12sp" />
    </LinearLayout>
</FrameLayout>
