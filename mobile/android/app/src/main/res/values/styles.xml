<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ── Main app theme ──────────────────────────────────────────────── -->
    <!-- Dark theme matching the site (#06060e background) -->
    <style name="Theme.Prizmbet" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">#06060e</item>
        <item name="android:statusBarColor">#06060e</item>
        <item name="android:navigationBarColor">#06060e</item>
        <item name="colorPrimary">#6366f1</item>
        <item name="colorPrimaryDark">#06060e</item>
        <item name="colorAccent">#818cf8</item>
    </style>

    <!-- ── Splash Screen theme (core-splashscreen, backward-compat) ────── -->
    <!--
        Activity is launched with this theme so the OS renders the splash
        immediately — no black flash.  Once installSplashScreen() detects
        that the page has loaded (isPageLoaded = true), Android transitions
        to postSplashScreenTheme (Theme.Prizmbet) automatically.
    -->
    <style name="Theme.Prizmbet.Starting" parent="Theme.SplashScreen">
        <!-- Dark background matching the app -->
        <item name="windowSplashScreenBackground">@color/bg_primary</item>
        <!-- PrizmBet logo (из frontend/prizmbet-logo.webp) -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/bg_primary</item>
        <!-- Theme applied after splash exits -->
        <item name="postSplashScreenTheme">@style/Theme.Prizmbet</item>
    </style>

</resources>
